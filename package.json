{
  "name": "@axelor/ui",
  "version": "0.7.0",
  "author": "Axelor",
  "license": "AGPL-3.0-only",
  "keywords": [
    "react",
    "components",
    "ui",
    "axelor"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*/index.ts",
    "./core/*": "./src/core/*/index.ts",
    "./icons/*": "./src/icons/*/index.ts"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "preinstall": "node scripts/check-pnpm.js",
    "format": "prettier -w '**/*.{ts,tsx,js,jsx,json,css,scss}'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "node scripts/build.js . -o dist",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@floating-ui/react": "^0.27.19",
    "@fluentui/priority-overflow": "^9.3.0",
    "@fluentui/react-context-selector": "^9.2.15",
    "@hello-pangea/dnd": "^18.0.1",
    "@material-symbols/font-400": "^0.43.0",
    "@material-symbols/metadata": "^0.43.0",
    "@types/qrcode": "^1.5.6",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "color": "^5.0.3",
    "csstype": "^3.2.3",
    "dayjs": "^1.11.20",
    "focus-trap": "^8.0.1",
    "immer": "^11.1.4",
    "jsbarcode": "^3.12.3",
    "qrcode": "^1.5.4",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-transition-group": "^4.4.5"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/react": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@types/node": "^24.12.0",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.12",
    "@vitejs/plugin-react": "^5.1.4",
    "commander": "^14.0.3",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.4",
    "globals": "^17.4.0",
    "i18next": "^25.10.10",
    "prettier": "^3.8.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6",
    "rimraf": "^6.1.3",
    "sass": "1.77.8",
    "semver": "^7.7.4",
    "storybook": "^10.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "~7.3.1",
    "vite-plugin-svgr": "^4.5.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@babel/*",
        "@eslint/*"
      ]
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
